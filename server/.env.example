# Postgres connection string (Neon). Required.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Port the server listens on (Render sets this automatically).
PORT=8080

# Comma-separated list of allowed frontend origins for CORS.
# Use "*" for local development. In production set it to your frontend URL,
# e.g. https://eco-recovery-hub-3r.vercel.app
CORS_ORIGIN=*
